# ============================================================
# AlphaClaw — D1 (Dustin's Agent) — Coolify Environment Variables
# Copy this to Coolify → Service → Environment Variables
# NEVER commit the filled-in version with real secrets
# ============================================================

# ── Required ─────────────────────────────────────────────────
# AlphaClaw web UI password (pick a strong one)
SETUP_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Your Coolify domain (set BEFORE first deploy so Google Chat works)
# Format: https://d1.yourdomain.com  (no trailing slash)
ALPHACLAW_BASE_URL=https://REPLACE_WITH_COOLIFY_DOMAIN

# ── GitHub (for workspace git sync) ──────────────────────────
GITHUB_TOKEN=REPLACE_WITH_GITHUB_PAT
GITHUB_WORKSPACE_REPO=mnjbold/alphaclaw_dustin

# ── AI Models (at least one required) ────────────────────────
# GitHub Copilot auth is set via AlphaClaw UI (gws auth)
# Fallback API keys:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Google Chat (service account — base64 encoded) ───────────
# Get the base64 of gen-lang-client-*.json:
#   base64 -w0 gen-lang-client-0768862569-d25b2b9e7693.json
GOOGLE_CHAT_SERVICE_ACCOUNT_B64=REPLACE_WITH_BASE64_OF_SA_JSON

# ── Google OAuth Client (for AlphaClaw's Google Workspace auth) ──
# Get the base64 of gog_client_secret.json:
#   base64 -w0 gog_client_secret.json
GOOGLE_OAUTH_CLIENT_B64=REPLACE_WITH_BASE64_OF_OAUTH_JSON

# ── Watchdog ──────────────────────────────────────────────────
WATCHDOG_AUTO_REPAIR=true
WATCHDOG_NOTIFICATIONS_DISABLED=false

# ── Dustin-specific tools (set after first boot) ─────────────
DUSTIN_CHAT_USER_ID=users/REPLACE_WITH_DUSTINS_CHAT_USER_ID
DUSTIN_FINANCE_SHEET_ID=REPLACE_ME
DUSTIN_IT_SHEET_ID=REPLACE_ME
DUSTIN_HR_SHEET_ID=REPLACE_ME
QUICKBOOKS_CLIENT_ID=REPLACE_ME
QUICKBOOKS_CLIENT_SECRET=REPLACE_ME
TSHEETS_API_KEY=REPLACE_ME
MONDAY_API_KEY=REPLACE_ME
JIRA_API_TOKEN=REPLACE_ME

# ── Port (Coolify usually sets this automatically) ────────────
PORT=3000
